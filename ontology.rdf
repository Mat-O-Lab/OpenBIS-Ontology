    <!-- http://w3id.org/matolab/openbis/Collection -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/Collection">
        <openbis:openbis_json_key>as.dto.experiment.Experiment</openbis:openbis_json_key>
        <rdfs:label>Collection</rdfs:label>
        <skos:altLabel>Experiment</skos:altLabel>
        <skos:definition>An OpenBIS Collection of Objects and DataSets.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/DataSet -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/DataSet">
        <rdfs:subClassOf rdf:resource="http://w3id.org/matolab/openbis/Collection"/>
        <openbis:openbis_json_key>as.dto.dataset.Dataset</openbis:openbis_json_key>
        <rdfs:label>Data Set</rdfs:label>
        <skos:definition>An folder where data files are stored. A data set has user-defined properties.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/Identifier -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/Identifier">
        <openbis:openbis_json_key>as.dto.experiment.id.ExperimentIdentifier</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.project.id.ProjectIdentifier</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.sample.id.SampleIdentifier</openbis:openbis_json_key>
        <rdfs:label>Identifier</rdfs:label>
        <skos:definition>A String as additional Identifier.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/Object -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/Object">
        <openbis:openbis_json_key>as.dto.sample.Sample</openbis:openbis_json_key>
        <rdfs:label>Object</rdfs:label>
        <skos:altLabel>Sample</skos:altLabel>
        <skos:definition>An OpenBIS entity of an object.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/PermanentIdentifier -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/PermanentIdentifier">
        <rdfs:subClassOf rdf:resource="http://w3id.org/matolab/openbis/Identifier"/>
        <openbis:openbis_json_key>as.dto.entitytype.id.EntityTypePermId</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.experiment.id.ExperimentPermId</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.person.id.PersonPermId</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.project.id.ProjectPermId</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.sample.id.SamplePermId</openbis:openbis_json_key>
        <openbis:openbis_json_key>as.dto.space.id.SpacePermId</openbis:openbis_json_key>
        <rdfs:label>Permanent Identifier</rdfs:label>
        <skos:definition>A additional String given by the OpenBIS data storage which will never be changed.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/Project -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/Project">
        <openbis:openbis_json_key>as.dto.project.Project</openbis:openbis_json_key>
        <rdfs:label>Project</rdfs:label>
        <skos:definition>An OpenBIS Project.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/Space -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/Space">
        <openbis:openbis_json_key>as.dto.space.Space</openbis:openbis_json_key>
        <rdfs:label>Space</rdfs:label>
        <skos:definition>An OpenBIS Space.</skos:definition>
    </owl:Class>
    


    <!-- http://w3id.org/matolab/openbis/User -->


    <owl:Class rdf:about="http://w3id.org/matolab/openbis/User">
        <owl:equivalentClass rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <owl:equivalentClass rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <openbis:openbis_json_key>as.dto.person.Person</openbis:openbis_json_key>
        <rdfs:label>User</rdfs:label>
        <skos:definition>An named openBIS user.</skos:definition>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/prov#Agent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Agent"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


