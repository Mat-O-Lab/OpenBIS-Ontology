    <!-- http://w3id.org/matolab/openbis/GeneralProtocols -->


    <owl:NamedIndividual rdf:about="http://w3id.org/matolab/openbis/GeneralProtocols">
        <rdf:type rdf:resource="http://w3id.org/matolab/openbis/Collection"/>
        <rdfs:label>General Protocols Collection, a default OpenBIS collection to contain the lab proceedures generally used in the lab.</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://w3id.org/matolab/openbis/Materials -->


    <owl:NamedIndividual rdf:about="http://w3id.org/matolab/openbis/Materials">
        <rdf:type rdf:resource="http://w3id.org/matolab/openbis/Space"/>
        <rdfs:label>Materials Space, a default OpenBIS space for material entities.</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://w3id.org/matolab/openbis/Methods -->


    <owl:NamedIndividual rdf:about="http://w3id.org/matolab/openbis/Methods">
        <rdf:type rdf:resource="http://w3id.org/matolab/openbis/Space"/>
        <rdfs:label>Methods Space, a default OpenBIS space for methods and proceedures.</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://w3id.org/matolab/openbis/Protocols -->


    <owl:NamedIndividual rdf:about="http://w3id.org/matolab/openbis/Protocols">
