###  http://w3id.org/matolab/openbis/Collection
<http://w3id.org/matolab/openbis/Collection> rdf:type owl:Class ;
                                             <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.experiment.Experiment" ;
                                             rdfs:label "Collection" ;
                                             <http://www.w3.org/2004/02/skos/core#altLabel> "Experiment" ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "An OpenBIS Collection of Objects and DataSets." .


###  http://w3id.org/matolab/openbis/DataSet
<http://w3id.org/matolab/openbis/DataSet> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://w3id.org/matolab/openbis/Collection> ;
                                          <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.dataset.Dataset" ;
                                          rdfs:label "Data Set" ;
                                          <http://www.w3.org/2004/02/skos/core#definition> "An folder where data files are stored. A data set has user-defined properties." .


###  http://w3id.org/matolab/openbis/Identifier
<http://w3id.org/matolab/openbis/Identifier> rdf:type owl:Class ;
                                             <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.experiment.id.ExperimentIdentifier" ,
                                                                                                "as.dto.project.id.ProjectIdentifier" ,
                                                                                                "as.dto.sample.id.SampleIdentifier" ;
                                             rdfs:label "Identifier" ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A String as additional Identifier." .


###  http://w3id.org/matolab/openbis/Object
<http://w3id.org/matolab/openbis/Object> rdf:type owl:Class ;
                                         <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.sample.Sample" ;
                                         rdfs:label "Object" ;
                                         <http://www.w3.org/2004/02/skos/core#altLabel> "Sample" ;
                                         <http://www.w3.org/2004/02/skos/core#definition> "An OpenBIS entity of an object." .


###  http://w3id.org/matolab/openbis/PermanentIdentifier
<http://w3id.org/matolab/openbis/PermanentIdentifier> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://w3id.org/matolab/openbis/Identifier> ;
                                                      <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.entitytype.id.EntityTypePermId" ,
                                                                                                         "as.dto.experiment.id.ExperimentPermId" ,
                                                                                                         "as.dto.person.id.PersonPermId" ,
                                                                                                         "as.dto.project.id.ProjectPermId" ,
                                                                                                         "as.dto.sample.id.SamplePermId" ,
                                                                                                         "as.dto.space.id.SpacePermId" ;
                                                      rdfs:label "Permanent Identifier" ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "A additional String given by the OpenBIS data storage which will never be changed." .


###  http://w3id.org/matolab/openbis/Project
<http://w3id.org/matolab/openbis/Project> rdf:type owl:Class ;
                                          <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.project.Project" ;
                                          rdfs:label "Project" ;
                                          <http://www.w3.org/2004/02/skos/core#definition> "An OpenBIS Project." .


###  http://w3id.org/matolab/openbis/Space
<http://w3id.org/matolab/openbis/Space> rdf:type owl:Class ;
                                        <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.space.Space" ;
                                        rdfs:label "Space" ;
                                        <http://www.w3.org/2004/02/skos/core#definition> "An OpenBIS Space." .


###  http://w3id.org/matolab/openbis/User
<http://w3id.org/matolab/openbis/User> rdf:type owl:Class ;
                                       owl:equivalentClass <http://www.w3.org/ns/prov#Agent> ,
                                                           <http://xmlns.com/foaf/0.1/Person> ;
                                       <http://w3id.org/matolab/openbis/openbis_json_key> "as.dto.person.Person" ;
                                       rdfs:label "User" ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "An named openBIS user." .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


