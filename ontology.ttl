                                                 owl:inverseOf <http://w3id.org/matolab/openbis/is_identifier_of> ;
                                                 rdfs:range <http://w3id.org/matolab/openbis/Identifier> ;
                                                 rdfs:label "has identifier"@en .


###  http://w3id.org/matolab/openbis/has_parent
